# agento-web environment variables
# Copy to .env.local for local development

# Server-side only — never exposed to the browser (no NEXT_PUBLIC_ prefix).
# The Next.js proxy at /api/[...path] injects these when forwarding to Spring Boot.

# URL of the agento-api backend (includes /api context path)
API_URL=http://localhost:8080/api

# API key — must match AGENTO_API_KEY set in agento-api.
# Leave empty when agento-api runs without authentication (dev mode).
API_KEY=your-secret-api-key-here
