# agento-web environment variables
# Copy to .env.local for local development

# Server-side only — never exposed to the browser (no NEXT_PUBLIC_ prefix).
# The Next.js proxy at /api/[...path] injects these when forwarding to Spring Boot.

# URL of the agento-api backend (includes /api context path)
API_URL=http://localhost:8080/api

# Keycloak OIDC — all server-side only
# Create a "agento-webapp" client in Keycloak with:
#   - Client protocol: openid-connect
#   - Access type: confidential
#   - Valid redirect URIs: http://localhost:3000/*
#   - Web origins: http://localhost:3000
KEYCLOAK_CLIENT_ID=agento-webapp
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret-here
KEYCLOAK_ISSUER=https://auth.bn.co.th/realms/agento

# next-auth session config
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
