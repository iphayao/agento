# agento-web environment variables
# Copy to .env.local for local development

# URL of the agento-api backend (includes /api context path)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# API key — must match AGENTO_API_KEY set in agento-api
# Leave empty when agento-api is running without authentication (dev mode)
NEXT_PUBLIC_API_KEY=your-secret-api-key-here
