# agento-worker environment variables

# LLM Provider selection: anthropic | openai
AI_PROVIDER=anthropic

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (used when AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# agento-api callback base URL
AGENTO_API_URL=http://localhost:8080
AGENTO_API_CALLBACK_TOKEN=change-me

# Database (used for direct reads if needed — prefer API calls)
DATABASE_URL=postgresql://agento:agento@localhost:54320/agento

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=agento
MINIO_SECRET_KEY=agento-secret
MINIO_BUCKET=agento-content

# Server
WORKER_PORT=8001
