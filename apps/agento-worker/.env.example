# agento-worker environment variables

# Spring Boot API callback URL (must be reachable from this service)
AGENTO_API_URL=http://localhost:8080/api
AGENTO_API_KEY=

# AI provider — openai (default) or anthropic
AI_PROVIDER=openai
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Worker settings
WORKER_PORT=8001
LOG_LEVEL=INFO
