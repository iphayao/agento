# agento-api environment variables

# PostgreSQL (matches infra/docker-compose defaults)
POSTGRES_USERNAME=agento
POSTGRES_PASSWORD=agento

# AI Provider (OpenAI-compatible)
AI_API_KEY=your-openai-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Server
SERVER_PORT=8080
