# agento-api environment variables — copy to .env for local dev
#
# IMPORTANT: This project requires JDK 21. Set JAVA_HOME before running:
#   export JAVA_HOME="/Users/Phayao/.antigravity/extensions/redhat.java-1.54.0-darwin-arm64/jre/21.0.10-macosx-aarch64"
# Lombok 1.18.32 (managed by Spring Boot 3.3.0) does not support Java 25.
#

# PostgreSQL (matches infra/docker-compose defaults)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:54320/agento
SPRING_DATASOURCE_USERNAME=agento
SPRING_DATASOURCE_PASSWORD=agento

# AI Provider (OpenAI-compatible)
AI_API_KEY=sk-your-openai-api-key-here
AI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4o-mini
# For other OpenAI-compatible providers, change AI_BASE_URL accordingly

# CORS — allow Next.js dev server
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Server
SERVER_PORT=8080
