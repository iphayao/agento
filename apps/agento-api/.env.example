# agento-api environment variables

# PostgreSQL (matches infra/docker-compose defaults)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:54320/agento
SPRING_DATASOURCE_USERNAME=agento
SPRING_DATASOURCE_PASSWORD=agento

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# agento-worker callback base URL
AGENT_WORKER_URL=http://localhost:8001

# JWT / Auth (TODO: configure in Phase 1)
# JWT_SECRET=change-me-min-32-chars
# JWT_EXPIRY_SECONDS=86400

# MinIO / S3
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=agento
MINIO_SECRET_KEY=agento-secret
MINIO_BUCKET=agento-content

# Server
SERVER_PORT=8080
