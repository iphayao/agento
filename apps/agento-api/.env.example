# agento-api environment variables

# PostgreSQL (matches infra/docker-compose defaults)
POSTGRES_USERNAME=agento
POSTGRES_PASSWORD=agento

# AI Provider (OpenAI-compatible)
AI_API_KEY=your-openai-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Security — Keycloak JWT validation
# Set KEYCLOAK_ENABLED=true and point KEYCLOAK_ISSUER_URI at your realm to enable auth
# Leave KEYCLOAK_ENABLED=false to disable authentication (dev mode only)
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/agento

# API key for internal worker callbacks (must match AGENTO_API_KEY in agento-worker)
# Leave empty to disable API key check (dev mode only)
AGENTO_API_KEY=your-secret-api-key-here

# Worker auth — set the same value in agento-worker/.env as WORKER_API_KEY
# Leave empty to disable worker authentication (dev mode only)
WORKER_API_KEY=your-worker-api-key-here

# AI timeouts (seconds)
AI_CONNECT_TIMEOUT=5
AI_READ_TIMEOUT=60

# Embedding Provider (Phase 3 — Brand Memory)
# Defaults to same key/URL as AI provider if not set separately
EMBEDDING_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSIONS=1536

# Server
SERVER_PORT=8080
