# ── Secret template — DO NOT commit real values ──────────────────────────────
# Fill in base64-encoded values and apply with: kubectl apply -f secrets.yaml
# Get base64: echo -n 'value' | base64
apiVersion: v1
kind: Secret
metadata:
  name: agento-secrets
  namespace: agento
type: Opaque
data:
  POSTGRES_PASSWORD:    REPLACE_WITH_BASE64
  AGENTO_API_KEY:       REPLACE_WITH_BASE64
  WORKER_API_KEY:       REPLACE_WITH_BASE64
  JWT_SECRET:           REPLACE_WITH_BASE64
  AI_API_KEY:           REPLACE_WITH_BASE64
  EMBEDDING_API_KEY:    REPLACE_WITH_BASE64
  REDIS_PASSWORD:       REPLACE_WITH_BASE64
