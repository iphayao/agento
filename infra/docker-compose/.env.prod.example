# ── Agento Production Environment Template ──────────────────────────────────
# Copy this file to .env.prod and fill in all values before deployment.
# NEVER commit .env.prod to version control.

# PostgreSQL
POSTGRES_DB=agento
POSTGRES_USER=agento
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# API Security
AGENTO_API_KEY=CHANGE_ME_min_32_chars_api_key_here
JWT_SECRET=CHANGE_ME_min_32_chars_jwt_secret_here
JWT_EXPIRATION_SECONDS=28800

# Worker Security
WORKER_API_KEY=CHANGE_ME_worker_key_matches_AGENTO_API_KEY

# AI Provider (OpenAI or compatible)
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_PROVIDER=openai

# Embedding
EMBEDDING_API_KEY=sk-...

# Rate Limiting
AI_RATE_LIMIT=10

# Ports (change if 8080/3000 are taken)
API_PORT=8080
WEB_PORT=3000

# Logging
LOG_LEVEL=INFO
